{
  "font": {
    "description": "绘图字体",
    "type": "string",
    "hint": "设置绘图字体，可自定义字体放置于-插件目录/assess/custom_font.ttf",
    "default": "cute_font.ttf"
  },
  "bg": {
    "description": "绘图背景",
    "type": "string",
    "hint": "设置绘图字体，可自定义字体放置于-插件目录/assess/xxx(.jpg/.png)",
    "default": "bg.jpg"
  },
  "max_temp": {
    "description": "最大缓存图片数量",
    "type": "int",
    "hint": "设置最大可缓存的图片数量",
    "default": 5
  },
  "divide_group": {
    "description": "分群控制",
    "type": "object",
    "hint": "分群控制设置",
    "obvious_hint": true,
    "items": {
      "divide_data": {
        "description": "启用分群存储",
        "type": "bool",
        "hint": "设置是否启用数据分群存储",
        "default": false
      },
      "group_block_method": {
        "description": "群组阻止模式",
        "type": "string",
        "hint": "设置群组的黑白名单模式",
        "default": "blacklist",
        "options": ["blacklist", "whitelist"]
      },
      "group_control_list": {
        "description": "群组名单列表",
        "type": "list",
        "hint": "设置群组名单列表，填群号(group_id)",
        "default": []
      },
      "user_block_method": {
        "description": "用户阻止模式",
        "type": "string",
        "hint": "设置用户的黑白名单模式",
        "default": "blacklist",
        "options": ["blacklist", "whitelist"]
      },
      "user_control_list": {
        "description": "用户名单列表",
        "type": "list",
        "hint": "设置用户名单列表，填用户ID(user_id)",
        "default": []
      }
    }
  }
}
